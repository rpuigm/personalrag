{
  "name": "memory-chat-dev",
  "image": "mcr.microsoft.com/devcontainers/base:debian-11",

  "containerEnv": {
    "DEBIAN_FRONTEND": "noninteractive",
    "PYTHON_VERSION": "3.11"
  },

   "onCreateCommand": "sudo apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*",
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },



  "remoteUser": "vscode"
}
