{
  "name": "memory-chat-dev",
  "image": "mcr.microsoft.com/devcontainers/base:debian-11",

  "containerEnv": {
    "DEBIAN_FRONTEND": "noninteractive",
    "PYTHON_VERSION": "3.11"
  },

   "onCreateCommand": "sudo apt-get update && apt-get install -y && curl && git && build-essential && rm -rf /var/lib/apt/lists/*",
  
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
  },



  "remoteUser": "vscode"
}
